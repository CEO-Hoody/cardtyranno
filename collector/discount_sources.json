 "note": "프테라노돈(pteranodon) 결제처 카드할인 스크래핑 레지스트리. 각 결제처 소스 페이지의 렌더링 텍스트에서 fields의 변수를 추출해 site/data.json 스키마로 적재.",
 "fields": [
  {
   "key": "plat",
   "label": "결제처(가맹점)명",
   "source": "레지스트리 고정값"
  },
  {
   "key": "card",
   "label": "카드사/카드명",
   "extract": "ISSUERS 키워드(삼성카드·현대카드·신한카드·KB국민카드·롯데카드·우리카드·하나카드·NH농협카드·BC카드·IBK·카카오·토스·네이버페이 등)"
  },
  {
   "key": "tab",
   "label": "카드사 탭",
   "extract": "card에서 정규화한 카드사"
  },
  {
   "key": "type",
   "label": "할인유형",
   "extract": "TYPE_KW(즉시할인·청구할인·캐시백·페이백·적립·쿠폰·바우처·포인트)"
  },
  {
   "key": "min",
   "label": "최소결제금액",
   "extract": "정규식 '([\\d,]+원) 이상'"
  },
  {
   "key": "disc",
   "label": "할인/적립 금액",
   "extract": "정규식 '\\d원|\\d%|\\d만원' (임계금액 'N원 이상' 제외 후)"
  },
  {
   "key": "cond",
   "label": "조건",
   "extract": "첫결제·1회·전월실적 등(보강 대상)"
  },
  {
   "key": "period",
   "label": "행사기간",
   "extract": "정규식 'MM.DD~MM.DD'"
  },
  {
   "key": "gubun",
   "label": "온라인/오프라인",
   "source": "레지스트리 고정값"
  },
  {
   "key": "domain",
   "label": "도메인",
   "source": "레지스트리 고정값"
  },
  {
   "key": "url",
   "label": "랜딩/제휴 URL",
   "source": "레지스트리 소스 URL"
  },
  {
   "key": "conf",
   "label": "신뢰도",
   "source": "자동수집=중, 수기검증=상"
  }
 ],
